# A long random string used to sign Flask sessions
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-something-long-and-random

# The event code attendees enter on the landing page
# Share this only on the printed invite / welcome table
EVENT_CODE=WELLSBULL159

# Password for the /admin interface
ADMIN_PASSWORD=picnicadmin2025
